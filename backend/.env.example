# backend/.env
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME
CLERK_SECRET_KEY=
FRONTEND_URL=http://localhost:5173
# Webhook signing secret (Clerk → Webhooks → your endpoint) — creates DB users on user.created
CLERK_WEBHOOK_SIGNING_SECRET=
# Stripe (Checkout + webhook — Dashboard → Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time premium price in cents (default 999 = $9.99)
STRIPE_PREMIUM_AMOUNT_CENTS=999
# Public URL of this API (used for local avatar URLs when S3 is not configured)
API_PUBLIC_URL=http://localhost:3000
# AWS S3 (optional — if all set, avatars go to S3; else files are stored under ./uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
# LLM for recipe JSON (OPENROUTER_* supported). Dish images use OpenAI Images API only:
# OPENAI_API_KEY=sk-...
# Optional: defaults to dall-e-3
# OPENAI_IMAGE_MODEL=dall-e-3
